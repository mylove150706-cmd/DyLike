<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:ignore="MissingDefaultResource">

    <me.lingci.lib.base.view.SmoothCurveView
        android:id="@+id/smooth_curve"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp24"
        android:visibility="invisible"
        tools:visibility="visible"
        android:layout_gravity="bottom"
        android:translationZ="-1dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/center_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_media_default"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="16:9"
            tools:ignore="ContentDescription" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:orientation="horizontal"
        android:padding="@dimen/dp8"
        android:background="@drawable/dkplayer_shape_standard_controller_top_bg"
        tools:ignore="UseCompoundDrawables">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:contentDescription="@string/app_name"
            android:padding="@dimen/dp8"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp40"
            android:gravity="center_vertical"
            android:maxLines="1"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_battery"
            tools:text="标题标题标题标题标题标题标题标题标题标题标题标题标题标题标题"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp40"
            android:layout_marginEnd="@dimen/dp16"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="00:00" />

        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp8"
            android:padding="4dp"
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="@color/white"
            tools:text="100%"
            app:layout_constraintTop_toTopOf="@+id/tv_time"
            app:layout_constraintBottom_toBottomOf="@+id/tv_time"
            app:layout_constraintEnd_toStartOf="@+id/tv_time" />

        <ImageView
            android:id="@+id/iv_rotate"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:layout_marginEnd="@dimen/dp16"
            android:gravity="center_vertical"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_screen_rotation"
            tools:text="@string/hint_play_full"
            android:textColor="@color/white"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@+id/tv_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/tv_dm_track"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:contentDescription="@string/action_dm_track"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_dm_track"
            app:layout_constraintBottom_toBottomOf="@id/iv_rotate"
            app:layout_constraintEnd_toStartOf="@+id/iv_dm_list" />

        <ImageView
            android:id="@+id/iv_dm_list"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:contentDescription="@string/app_name"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_danmu_list"
            app:layout_constraintBottom_toBottomOf="@id/iv_rotate"
            app:layout_constraintEnd_toStartOf="@+id/iv_subtitle_audio" />

        <ImageView
            android:id="@+id/iv_subtitle_audio"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:gravity="center_vertical"
            android:padding="@dimen/dp8"
            app:tint="@color/white"
            android:src="@drawable/ic_subtitle_audio"
            tools:text="@string/hint_play_full"
            android:textColor="@color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/iv_rotate"
            app:layout_constraintEnd_toStartOf="@+id/iv_rotate"
            tools:visibility="visible"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/iv_media_info"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            app:layout_constraintEnd_toStartOf="@+id/tv_dm_track"
            app:layout_constraintBottom_toBottomOf="@id/tv_dm_track"
            app:tint="@color/white"
            android:src="@drawable/ic_info_outline_24"
            android:contentDescription="@string/app_name" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/end_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp16"
        android:layout_marginBottom="@dimen/dp8"
        android:layout_gravity="end|center_vertical">

        <ImageView
            android:id="@+id/iv_dm_conf"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/iv_video_conf"
            android:src="@drawable/ic_danmu_config"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/iv_video_conf"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_dm_conf"
            app:layout_constraintBottom_toTopOf="@+id/iv_screenshot"
            app:tint="@color/white"
            android:src="@drawable/ic_video_settings_24"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/iv_screenshot"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_video_conf"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/white"
            android:src="@drawable/ic_screenshot"
            android:contentDescription="@string/app_name" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/dkplayer_shape_stardard_controller_bottom_bg"
        android:paddingBottom="@dimen/dp16">

        <ImageView
            android:id="@+id/cb_dm_show"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:contentDescription="@string/app_name"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_danmu_selector"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_smooth_curve"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar" />

        <ImageView
            android:id="@+id/tv_select_ep"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:layout_marginEnd="@dimen/dp24"
            android:contentDescription="@string/action_select_ep"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_ep_list"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/tv_select_dm"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:contentDescription="@string/action_select_dm"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_dm_select"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_select_ep"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp10"
            android:maxLines="1"
            android:paddingStart="@dimen/dp16"
            android:paddingEnd="@dimen/dp8"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:fontFeatureSettings="tnum"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/play_seekbar"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar"
            tools:text="00:11 / 23:12" />

        <ImageView
            android:id="@+id/iv_play_sync"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_progress"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar"
            android:src="@drawable/ic_sync_24"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/iv_smooth_curve"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_play_sync"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar"
            android:src="@drawable/ic_dm_smooth"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/tv_play_speed"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:contentDescription="@string/action_speed"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_play_speed"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_select_dm"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar"  />

        <!-- 手动进入画中画按钮 -->
        <ImageView
            android:id="@+id/iv_pip"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_pip"
            android:contentDescription="@string/app_name"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_play_speed"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar" />

        <androidx.appcompat.widget.AppCompatSeekBar
            android:id="@+id/play_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:max="1000"
            android:progressBackgroundTint="@color/grey_500"
            android:secondaryProgressTint="@color/grey_300"
            android:progressTint="@color/view_accent_light"
            android:thumbTint="@color/view_accent_light"
            app:layout_constraintBottom_toTopOf="@id/tv_select_ep"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/play_btn"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp4"
            app:layout_constraintEnd_toStartOf="@+id/iv_play_next"
            app:layout_constraintBottom_toTopOf="@+id/play_seekbar"
            android:background="@null"
            android:contentDescription="@string/app_name"
            android:src="@drawable/dkplayer_selector_play_button"
            android:visibility="visible"
            app:tint="#BFFFFFFF"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/iv_play_next"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            android:layout_marginEnd="@dimen/dp24"
            app:layout_constraintBottom_toTopOf="@+id/play_seekbar"
            app:layout_constraintEnd_toEndOf="parent"
            android:src="@drawable/ic_skip_next"
            app:tint="#BFFFFFFF"
            android:contentDescription="@string/app_name" />

        <ImageView
            android:id="@+id/iv_play_previous"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:padding="@dimen/dp8"
            android:layout_marginStart="@dimen/dp24"
            app:layout_constraintBottom_toTopOf="@+id/play_seekbar"
            app:layout_constraintEnd_toStartOf="@+id/play_btn"
            android:src="@drawable/ic_skip_previous"
            app:tint="#BFFFFFFF"
            android:contentDescription="@string/app_name" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_tips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:visibility="visible"
        android:textColor="@color/white"
        tools:text="跳过片头"
        android:paddingTop="@dimen/dp4"
        android:paddingBottom="@dimen/dp4"
        android:paddingStart="@dimen/dp8"
        android:paddingEnd="@dimen/dp8"
        android:layout_marginStart="@dimen/dp24"
        android:layout_marginBottom="@dimen/dp96"
        android:background="@drawable/bg_radius_stroke_8_shape"
        android:layout_gravity="start|bottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/play_seekbar"/>

    <TextView
        android:id="@+id/tv_sub_tips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:visibility="visible"
        android:textColor="@color/white"
        tools:text="其他消息"
        android:paddingTop="@dimen/dp4"
        android:paddingBottom="@dimen/dp4"
        android:paddingStart="@dimen/dp8"
        android:paddingEnd="@dimen/dp8"
        android:layout_marginStart="@dimen/dp24"
        android:layout_marginBottom="@dimen/dp128"
        android:background="@drawable/bg_radius_stroke_8_shape"
        android:layout_gravity="start|bottom"/>

</FrameLayout>