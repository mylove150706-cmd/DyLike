<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/play_btn"
        android:layout_width="@dimen/dp96"
        android:layout_height="@dimen/dp96"
        android:layout_gravity="center"
        android:background="@null"
        app:tint="#D5FFFFFF"
        android:padding="@dimen/dkplayer_default_spacing"
        android:scaleType="fitCenter"
        android:src="@drawable/dkplayer_selector_play_button"
        android:visibility="gone"
        tools:visibility="visible"
        tools:ignore="ContentDescription" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/dp32"
        android:layout_gravity="top">

        <Space
            android:id="@+id/space_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp80"
            tools:ignore="MissingConstraints" />

        <me.lingci.dy.player.view.NodeSeekBar
            android:id="@+id/speed_node"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dp8"
            app:layout_constraintTop_toBottomOf="@+id/space_top"
            android:visibility="gone"
            tools:visibility="visible"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom">

        <ImageView
            android:id="@+id/play_like"
            android:layout_width="@dimen/dp48"
            android:layout_height="@dimen/dp48"
            app:layout_constraintBottom_toTopOf="@+id/layout_comment"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@null"
            android:padding="@dimen/dkplayer_default_spacing"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_like"
            app:tint="@color/like_selector"
            android:visibility="visible"
            tools:visibility="visible"
            tools:ignore="ContentDescription" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_comment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/iv_full"
            app:layout_constraintEnd_toEndOf="parent"
            android:visibility="visible"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/play_comment"
                android:layout_width="@dimen/dp48"
                android:layout_height="@dimen/dp32"
                app:layout_constraintTop_toTopOf="parent"
                android:background="@null"
                android:padding="@dimen/dkplayer_default_spacing_small"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_comment"
                app:tint="@color/like_selector"
                tools:ignore="ContentDescription,MissingConstraints" />

            <TextView
                android:id="@+id/tv_comment_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/play_comment"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:gravity="center_horizontal"
                android:visibility="gone"
                tools:text="999+"
                tools:visibility="visible" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageView
            android:id="@+id/iv_full"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:padding="@dimen/dp8"
            android:contentDescription="@string/hint_play_full"
            android:textColor="@color/white"
            android:visibility="gone"
            android:src="@drawable/ic_fullscreen_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/iv_more"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/iv_more"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:padding="@dimen/dp8"
            android:contentDescription="@string/action_more"
            android:textColor="@color/white"
            android:visibility="gone"
            android:src="@drawable/ic_more_vert_24"
            app:tint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/play_seekbar"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="5dp"
            android:lineSpacingExtra="1dp"
            android:paddingHorizontal="@dimen/dp12"
            android:paddingBottom="@dimen/dp8"
            tools:text="标题标题标题标题标题标题标题标题标题标题标题标题标题标题标题"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:minLines="1"
            android:maxLines="3"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="5dp"
            android:lineSpacingExtra="4dp"
            android:maxLines="1"
            tools:text="2x"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/tv_progress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="5dp"
            android:lineSpacingExtra="4dp"
            android:maxLines="1"
            tools:text="00:11 / 23:12"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/play_seekbar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_page"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp16"
            android:elevation="5dp"
            android:lineSpacingExtra="4dp"
            android:maxLines="1"
            tools:text="1/100"
            android:textColor="@color/grey_300"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/play_seekbar"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible" />

        <androidx.appcompat.widget.AppCompatSeekBar
            android:id="@+id/play_seekbar"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp32"
            android:background="@null"
            android:max="1000"
            android:progressBackgroundTint="@color/grey_400"
            android:progressTint="@color/white"
            android:thumbTint="@color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/tv_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:progress="500"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>